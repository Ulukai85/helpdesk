DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk"
PORT=3000
CLIENT_URL=http://localhost:5173
BETTER_AUTH_SECRET=     # generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password-min-12-chars>
WEBHOOK_SECRET=     # generate: openssl rand -hex 32 — SendGrid Inbound Parse can't send custom headers, so configure the Parse URL as https://<host>/api/webhooks/inbound-email?token=<WEBHOOK_SECRET>
OPENAI_API_KEY=     # your OpenAI API key
SENDGRID_API_KEY=     # your SendGrid API key, needs "Mail Send" permission
SENDGRID_FROM_EMAIL=  # must be a verified sender identity/domain in SendGrid
