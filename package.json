{
  "name": "helpdesk",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev:server": "bun run --cwd server dev",
    "dev:client": "bun run --cwd client dev",
    "db:studio": "bun run --cwd server studio",
    "db:studio:test": "bun --env-file=server/.env.test run --cwd server studio",
    "db:migrate:test": "bun --env-file=server/.env.test run --cwd server migrate:reset",
    "test": "bun --env-file=server/.env.test playwright test",
    "test:ui": "bun --env-file=server/.env.test playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3"
  }
}
